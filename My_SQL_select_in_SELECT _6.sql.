ТОЛЬКО КОЛЛЕРИРОВАННЫЕ ЗАПРОСЫ:

select  distinct title 'заказ_название', author 'заказ_автор'
, (select sum(amount) from orrder o2 
  where o2.title=o.title and o2.author<=>o.author) as "кол-во"
, if(   (select sum(amount) from orrder o2 
  where o2.title=o.title and o2.author<=>o.author)>50, 'бестселлер',
     if(    (select sum(amount) from orrder o2 
  where o2.title=o.title and o2.author<=>o.author)>20, 'хит', 'новинка') ) as 'ранг'
, round((select avg(price) from orrder o2 
  where o2.title=o.title and o2.author<=>o.author)) as 'сред_чек'
, round(ifnull((((select sum(amount) from orrder o2 
  where o2.title=o.title and o2.author<=>o.author)/ (select s.amount from store s 
                where o.title=s.title and o.author<=>s.author))),0)*100) as '%_от_склада'
 from orrder o
order by 3 desc
;

ВАРИАНТ ЧУТЬ ПРОЩЕ:

select  o.title 'заказ_название', o.author 'заказ_автор'
, sum(amount) as "кол-во"
, if(sum(amount)>50, 'бестселлер',
     if(sum(amount)>20, 'хит', 'новинка') ) as 'ранг'
, round(avg(price)) as 'сред_чек'
, round(ifnull(((sum(amount)/ (select s.amount from store s 
                where o.title=s.title and o.author<=>s.author))),0)*100) as '%_от_склада'
 from orrder o
 group by o.title, o.author
 order by 3 desc;
